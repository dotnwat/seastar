# --------------------------------------------------------------------------
# TLS test certificate generation
# --------------------------------------------------------------------------

# Generate a self-signed CA and server certificate for testing.
# Mirrors CMake's seastar_add_certgen() function.
genrule(
    name = "testcrt_gen",
    outs = [
        "test.crt",
        "test.crt.der",
        "test.key",
        "catest.pem",
        "catest.key",
    ],
    cmd = """
        set -e
        DOMAIN=scylladb.org
        SERVER=test
        COMMON=$$SERVER.$$DOMAIN
        # Generate CA key and self-signed cert
        openssl genpkey -quiet -out $(location catest.key) -algorithm RSA -pkeyopt rsa_keygen_bits:4096
        openssl req -x509 -new -nodes -key $(location catest.key) -days 3650 \
            -out $(location catest.pem) \
            -subj "/C=SE/ST=Stockholm/L=Stockholm/O=$$DOMAIN/OU=$$DOMAIN/CN=$$COMMON"
        # Generate server key and CSR
        openssl genpkey -quiet -out $(location test.key) -algorithm RSA -pkeyopt rsa_keygen_bits:4096
        openssl req -new -key $(location test.key) -out test.csr \
            -subj "/C=SE/ST=Stockholm/L=Stockholm/O=$$DOMAIN/OU=$$DOMAIN/CN=$$COMMON" \
            -addext "subjectAltName=email:alt1@$$DOMAIN,email:alt2@$$DOMAIN,IP:127.0.0.1,DNS:$$COMMON"
        # Sign server cert with CA
        openssl x509 -req -in test.csr -CA $(location catest.pem) -CAkey $(location catest.key) \
            -CAcreateserial -out $(location test.crt) -days 3650 \
            -copy_extensions copy
        # DER format
        openssl x509 -in $(location test.crt) -out $(location test.crt.der) -outform der
        # Make cert files writable (tests may copy them)
        chmod 644 $(location test.crt) $(location test.key) $(location catest.pem)
    """,
)

genrule(
    name = "othercrt_gen",
    outs = [
        "other.crt",
        "other.crt.der",
        "other.key",
        "caother.pem",
        "caother.key",
    ],
    cmd = """
        set -e
        DOMAIN=apa.org
        SERVER=other
        COMMON=$$SERVER.$$DOMAIN
        openssl genpkey -quiet -out $(location caother.key) -algorithm RSA -pkeyopt rsa_keygen_bits:4096
        openssl req -x509 -new -nodes -key $(location caother.key) -days 3650 \
            -out $(location caother.pem) \
            -subj "/C=SE/ST=Stockholm/L=Stockholm/O=$$DOMAIN/OU=$$DOMAIN/CN=$$COMMON"
        openssl genpkey -quiet -out $(location other.key) -algorithm RSA -pkeyopt rsa_keygen_bits:4096
        openssl req -new -key $(location other.key) -out other.csr \
            -subj "/C=SE/ST=Stockholm/L=Stockholm/O=$$DOMAIN/OU=$$DOMAIN/CN=$$COMMON" \
            -addext "subjectAltName=email:alt1@$$DOMAIN,email:alt2@$$DOMAIN,IP:127.0.0.1,DNS:$$COMMON"
        openssl x509 -req -in other.csr -CA $(location caother.pem) -CAkey $(location caother.key) \
            -CAcreateserial -out $(location other.crt) -days 3650 \
            -copy_extensions copy
        openssl x509 -in $(location other.crt) -out $(location other.crt.der) -outform der
        chmod 644 $(location other.crt) $(location other.key) $(location caother.pem)
    """,
)

# Mutual TLS certificates: CA + server + 2 client certs.
# Mirrors CMake's seastar_gen_mtls_certs() function.
genrule(
    name = "mtls_certs_gen",
    outs = [
        "mtls_ca.crt",
        "mtls_ca.key",
        "mtls_server.crt",
        "mtls_server.key",
        "mtls_client1.crt",
        "mtls_client1.key",
        "mtls_client2.crt",
        "mtls_client2.key",
    ],
    cmd = """
        set -e
        EXT="subjectAltName = IP:127.0.0.1"
        # CA
        openssl ecparam -name prime256v1 -genkey -noout -out $(location mtls_ca.key)
        openssl req -new -x509 -sha256 -key $(location mtls_ca.key) \
            -out $(location mtls_ca.crt) \
            -subj "/C=GB/ST=London/L=London/O=Redpanda Data/OU=Core/CN=redpanda.com" \
            -addext "$$EXT"
        # Server
        openssl ecparam -name prime256v1 -genkey -noout -out $(location mtls_server.key)
        openssl req -new -sha256 -key $(location mtls_server.key) -out mtls_server.csr \
            -subj "/C=GB/ST=London/L=London/O=Redpanda Data/OU=Core/CN=redpanda.com"
        openssl x509 -req -days 1000 -sha256 -set_serial 1 \
            -in mtls_server.csr -CA $(location mtls_ca.crt) -CAkey $(location mtls_ca.key) \
            -out $(location mtls_server.crt)
        # Client 1
        openssl ecparam -name prime256v1 -genkey -noout -out $(location mtls_client1.key)
        openssl req -new -sha256 -key $(location mtls_client1.key) -out mtls_client1.csr \
            -subj "/C=GB/ST=London/L=London/O=Redpanda Data/OU=Core/CN=client1.org"
        openssl x509 -req -days 1000 -sha256 -set_serial 2 \
            -in mtls_client1.csr -CA $(location mtls_ca.crt) -CAkey $(location mtls_ca.key) \
            -out $(location mtls_client1.crt)
        # Client 2
        openssl ecparam -name prime256v1 -genkey -noout -out $(location mtls_client2.key)
        openssl req -new -sha256 -key $(location mtls_client2.key) -out mtls_client2.csr \
            -subj "/C=GB/ST=London/L=London/O=Redpanda Data/OU=Core/CN=client2.org"
        openssl x509 -req -days 1000 -sha256 -set_serial 3 \
            -in mtls_client2.csr -CA $(location mtls_ca.crt) -CAkey $(location mtls_ca.key) \
            -out $(location mtls_client2.crt)
        chmod 644 $(location mtls_ca.crt) $(location mtls_ca.key) \
            $(location mtls_server.crt) $(location mtls_server.key) \
            $(location mtls_client1.crt) $(location mtls_client1.key) \
            $(location mtls_client2.crt) $(location mtls_client2.key)
    """,
)

