    copts = [
        "-Wno-unused-variable",
        "-Wno-unused-result",
        "-Wno-unused-but-set-variable",
        # Prevent TLS/malloc recursion when linked as a shared library.
        # Seastar overrides malloc/free, which access thread_local variables.
        # With the default global-dynamic TLS model, __tls_get_addr may call
        # free(), causing infinite recursion. initial-exec places TLS in the
        # static TLS block, bypassing __tls_get_addr entirely.
        "-ftls-model=initial-exec",
        "-fno-semantic-interposition",
